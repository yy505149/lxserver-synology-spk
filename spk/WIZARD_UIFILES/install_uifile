[
  {
    "step_title": "LX Server Initial Settings",
    "items": [
      {
        "type": "textfield",
        "desc": "Configure service port (default: 9527)",
        "subitems": [
          {
            "key": "WIZARD_SERVICE_PORT",
            "desc": "Service Port",
            "defaultValue": "9527",
            "validator": {
              "allowBlank": true,
              "regex": "^(6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5]?[0-9]{1,4})$",
              "errorText": "Please enter a valid port (1-65535)."
            }
          }
        ]
      },
      {
        "type": "password",
        "desc": "Set admin password (default: 123456)",
        "subitems": [
          {
            "key": "WIZARD_ADMIN_PASSWORD",
            "desc": "Admin Password",
            "defaultValue": "",
            "validator": {
              "allowBlank": true
            }
          }
        ]
      }
    ]
  }
]
